# ============================================================
# BACKEND .env.example  ─  SERVER + SECRETS TEMPLATE
# ============================================================
# Copy this file:
#
#   Development:  cp .env.example .env.development
#   Production:   cp .env.example .env.production
#
# RULES:
#   ✅ Server-side secrets only
#   ✅ Database connection config
#   ✅ JWT, Twilio, Razorpay, WhatsApp
#   ❌ MUST NOT contain NEXT_PUBLIC_* variables
#   ❌ MUST NOT contain Postgres superuser vars (use root .env)
# ============================================================

NODE_ENV=development

# ── Server ───────────────────────────────────────────────────
PORT=8000

# ── Database ─────────────────────────────────────────────────
# In Docker, DB_HOST should match the compose service name (postgres)
# Locally, use localhost or 127.0.0.1
DB_HOST=postgres
DB_PORT=5432
DB_NAME=malicc_dev
DB_USER=malicc_user
DB_PASSWORD=change_me

# ── JWT ──────────────────────────────────────────────────────
# Generate a strong secret: openssl rand -base64 64
JWT_SECRET=change_me_in_production

# ── CORS ─────────────────────────────────────────────────────
# Comma-separated list. Must include all frontend origins.
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,https://studio.apollographql.com

# ── Twilio (set TWILIO_DISABLED=true to skip validation in dev) ──
TWILIO_DISABLED=true
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
TWILIO_VERIFY_SERVICE_SID=
TWILIO_API_SID=
TWILIO_API_SECRET=

# ── Razorpay ─────────────────────────────────────────────────
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# ── Meta WhatsApp Cloud API ───────────────────────────────────
META_WHATSAPP_ACCESS_TOKEN=
META_WHATSAPP_PHONE_NUMBER_ID=
META_WHATSAPP_BUSINESS_ACCOUNT_ID=
META_WHATSAPP_API_VERSION=v25.0
META_WHATSAPP_WEBHOOK_VERIFY_TOKEN=

# ── Malicc Store / Event Bridge ──────────────────────────────
STORE_ID=malicc_dev_001
EVENT_BRIDGE_SECRET=
HQ_EVENT_ENDPOINT=http://localhost:3001/api/ingest/events
HQ_USAGE_ENDPOINT=http://localhost:3001/api/ingest/usage
